# Firebase Configuration Template
# Copy this file to .env.local and fill in your Firebase credentials
# DO NOT commit .env.local to git - it contains sensitive information

# Get these values from Firebase Console:
# 1. Go to https://console.firebase.google.com
# 2. Select your project
# 3. Click Settings (gear icon) → Project settings
# 4. Scroll to "Your apps" → Click your web app
# 5. Copy the firebaseConfig values below

# Your Firebase API Key
VITE_FIREBASE_API_KEY=AIzaSy_YOUR_API_KEY_HERE

# Your Firebase Auth Domain
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Your Firebase Project ID
VITE_FIREBASE_PROJECT_ID=your-project-id

# Your Firebase Storage Bucket
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Your Firebase Messaging Sender ID
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012

# Your Firebase App ID
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef
